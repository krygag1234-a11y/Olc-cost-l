OLCRTC_MANAGER_USER='admin'
OLCRTC_JITSI_INSECURE_TLS=1
OLCRTC_DIRECT_CIDRS=/var/lib/olcrtc/ru-cidrs.txt
OLCRTC_DIRECT_DOMAINS=/var/lib/olcrtc/ru-direct-domains.txt
OLCRTC_BLOCKED_TOR_DOMAINS=/var/lib/olcrtc/ru-blocked-tor-domains.txt
OLCRTC_FORCE_TOR_DOMAINS=/var/lib/olcrtc/force-tor-domains.txt

# Olc-cost-l split — обновление списков:
#   /opt/Olc-cost-l/scripts/setup-split-ru.sh
#   /opt/Olc-cost-l/scripts/fetch-ru-cidrs.sh
#   /opt/Olc-cost-l/scripts/fetch-ru-direct-domains.sh
#   /opt/Olc-cost-l/scripts/fetch-ru-blocked-tor-domains.sh
OLCRTC_WARP_PROXY=127.0.0.1:40000

OLCRTC_WARP_MODE=proxy

OLCRTC_WARP_AUTOCONNECT=1

OLCRTC_WARP_PLUS=0

OLCRTC_WARP_LICENSE=
