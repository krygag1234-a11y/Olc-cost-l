# Minimal zapret for OlcRTC VPS — direct egress only (not Tor loopback).
# Full zapret4rocket config is too heavy for small VPS ipset load; use RKN strategy #2 hostlist.
FWTYPE=iptables
SET_MAXELEM=262144
IPSET_OPT="hashsize 65536 maxelem $SET_MAXELEM"
DESYNC_MARK=0x40000000
DESYNC_MARK_POSTNAT=0x20000000

TPWS_ENABLE=0
TPWS_SOCKS_ENABLE=0
NFQWS_ENABLE=1
NFQWS_PORTS_TCP=80,443
NFQWS_PORTS_UDP=443
NFQWS_TCP_PKT_OUT=9
NFQWS_TCP_PKT_IN=3
NFQWS_UDP_PKT_OUT=9
NFQWS_UDP_PKT_IN=0

# Strategy ~2 from zapret4rocket (msn.com SNI fake) on olcrtc merged hostlist
NFQWS_OPT="
--filter-tcp=80 --methodeol --hostlist=/opt/zapret/ipset/zapret-hosts-user.txt --new
--filter-tcp=443 --hostlist=/opt/zapret/ipset/zapret-hosts-user.txt --dpi-desync=fake --dpi-desync-fooling=ts,badsum --dpi-desync-fake-tls=/opt/zapret/files/fake/stun.bin --dpi-desync-fake-tls=/opt/zapret/files/fake/tls_clienthello_max_ru.bin --dpi-desync-fake-tls-mod=sni=msn.com
"
