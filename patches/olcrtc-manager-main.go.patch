+func parseLogsRequest(r *http.Request) (clientID, roomID, transport string, ok bool) {
+	if q := r.URL.Query(); q.Get("client_id") != "" && q.Get("room_id") != "" && q.Get("transport") != "" {
+		return q.Get("client_id"), q.Get("room_id"), q.Get("transport"), true
