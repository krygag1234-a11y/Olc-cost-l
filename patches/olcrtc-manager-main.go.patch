+
+	parts := strings.Split(strings.TrimPrefix(r.URL.Path, "/api/logs/"), "/")
+	if len(parts) < 3 || parts[0] == "" || parts[len(parts)-1] == "" {
+		return "", "", "", false
+	}
+	clientID = parts[0]
+	transport = parts[len(parts)-1]
+	roomID = strings.Join(parts[1:len(parts)-1], "/")
+	roomID = strings.Replace(roomID, "https:/", "https://", 1)
+	roomID = strings.Replace(roomID, "http:/", "http://", 1)
+	if roomID == "" {
+		return "", "", "", false
+	}
+	return clientID, roomID, transport, true
