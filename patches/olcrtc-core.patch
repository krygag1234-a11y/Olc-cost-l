+func (s *Server) shouldDialDirect(host string) bool {
+	if s.directCIDRs == nil || s.directCIDRs.Len() == 0 {
+		return false
+	}
+	host = strings.TrimSpace(host)
+	if host == "" {
+		return false
+	}
+	if ip := net.ParseIP(host); ip != nil {
+		return s.directCIDRs.Contains(ip)
+	}
+	ctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)
+	defer cancel()
+	ips, err := s.resolver.LookupIP(ctx, "ip4", host)
+	if err != nil || len(ips) == 0 {
+		return false
+	}
+	for _, ip := range ips {
+		if s.directCIDRs.Contains(ip) {
+			return true
+		}
+	}
+	return false
+}
